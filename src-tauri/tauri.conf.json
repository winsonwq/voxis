{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voix",
  "version": "0.1.0",
  "identifier": "com.voxis.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "title": "Voix",
        "width": 360,
        "height": 480,
        "resizable": false,
        "center": true,
        "visible": true,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://api.openai.com https://*.ollama.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "shortDescription": "AI voice input with real-time polish",
    "longDescription": "Voix transforms your speech into polished, professional text in any application. Local transcription with Whisper, AI text polishing, works everywhere.",
    "category": "public.app-category-productivity"
  },
  "plugins": {}
}
